{
  "manifest_version": 3,
  "name": "Orbit — Aiopad Companion",
  "version": "1.0.0",
  "description": "Select text on any page to instantly send it to Aiopad or ask Orbit AI a question.",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": [
    "<all_urls>",
    "https://integrate.api.nvidia.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Orbit Settings"
  }
}
